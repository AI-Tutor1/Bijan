{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd portal && npm ci && npm run build",
  "outputDirectory": "portal/.next",
  "installCommand": "echo 'install handled by buildCommand'",
  "framework": "nextjs",
  "functions": {
    "portal/app/api/jobs/[id]/evaluate/route.ts": { "maxDuration": 60 },
    "portal/app/api/intake/screenshot/route.ts": { "maxDuration": 60 }
  }
}
